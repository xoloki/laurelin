#!/usr/bin/env bash
# Runs the full integration test cycle against a local validator.
# Prerequisites: docker-compose -f start-testnet.yml up
set -e

PAYER_KEYPAIR=./accounts/account1.json
RPC_URL=http://127.0.0.1:8899

echo "==> Running trusted setup (generates PK/VK files)..."
(cd circuit && go run ./setup/)

echo "==> Building SBF program..."
cargo build-sbf

echo "==> Configuring Solana CLI..."
solana config set --url "$RPC_URL" --keypair "$PAYER_KEYPAIR"

echo "==> Deploying program..."
DEPLOY_OUTPUT=$(solana program deploy target/deploy/laurelin.so)
echo "$DEPLOY_OUTPUT"
PROGRAM_ID=$(echo "$DEPLOY_OUTPUT" | awk '/Program Id:/ {print $3}')
echo "Program ID: $PROGRAM_ID"

echo "==> Running integration test..."
(cd circuit && go run ./cmd/client/ "$PROGRAM_ID" "../$PAYER_KEYPAIR")

echo "==> Integration test passed."
