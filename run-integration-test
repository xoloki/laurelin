#!/usr/bin/env bash
# Runs the full integration test cycle against a local validator.
# Prerequisites: solana-test-validator running
set -e

PAYER_KEYPAIR=./accounts/account1.json
RPC_URL=http://127.0.0.1:8899
SETUP_DIR=/tmp/laurelin-setup

echo "==> Running trusted setup (generates PK/VK files)..."
cargo run --release --package laurelin-circuit --bin laurelin-setup \
    -- --output-dir "$SETUP_DIR"
cp "$SETUP_DIR"/deposit_vk_generated.rs  src/deposit_vk_generated.rs
cp "$SETUP_DIR"/withdraw_vk_generated.rs src/withdraw_vk_generated.rs
cp "$SETUP_DIR"/transfer_vk_generated.rs src/transfer_vk_generated.rs

echo "==> Building SBF program..."
cargo build-sbf

echo "==> Configuring Solana CLI..."
solana config set --url "$RPC_URL" --keypair "$PAYER_KEYPAIR"

echo "==> Airdropping SOL to payer..."
solana airdrop 100

echo "==> Deploying program..."
DEPLOY_OUTPUT=$(solana program deploy target/deploy/laurelin.so)
echo "$DEPLOY_OUTPUT"
PROGRAM_ID=$(echo "$DEPLOY_OUTPUT" | awk '/Program Id:/ {print $3}')
echo "Program ID: $PROGRAM_ID"

echo "==> Running integration test..."
cargo run --release --package laurelin-wallet --bin integration-test \
    -- "$PROGRAM_ID" "$PAYER_KEYPAIR" "$SETUP_DIR"

echo "==> Integration test passed."
