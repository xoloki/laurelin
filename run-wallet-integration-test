#!/bin/bash
# Full wallet integration test.
#
# Usage: run-wallet-integration-test [N [BASE_DIR]]
#   N         number of wallets (default 4, minimum 4 for ring transfers)
#   BASE_DIR  root for per-wallet dirs (default ~/.laurelin)
#
# Expects a local validator running with the Laurelin program deployed and
# proving keys present.  Requires: laurelin-wallet, solana CLI.

set -euo pipefail

n=4
if [ -n "${1:-}" ]; then n="$1"; fi
if [ "$n" -lt 4 ]; then
    echo "Error: need at least 4 wallets for ring transfers"
    exit 1
fi

base="$HOME/.laurelin"
if [ -n "${2:-}" ]; then
    if [ "$2" = "$HOME" ]; then echo "can't use $HOME as base"; exit 1; fi
    base="$2"
fi

program=4eesfezqbNcYSJLmQqvxN38CdsccYGFYUaZdBgQp7a2L
pk_dir=/tmp/laurelin-setup
url=http://localhost:8899

PASS=0; FAIL=0

check() {
    local desc="$1" expected="$2" actual="$3"
    if echo "$actual" | grep -qF "$expected"; then
        echo "  PASS: $desc"
        ((PASS++)) || true
    else
        echo "  FAIL: $desc"
        echo "    expected: $expected"
        echo "    got:      $actual"
        ((FAIL++)) || true
    fi
}

lw() {
    local j=$1; shift
    laurelin-wallet --url "$url" \
        --config "$base/$j/config.json" \
        --wallet "$base/$j/wallet.json" "$@" 2>/dev/null
}

# ── Setup ─────────────────────────────────────────────────────────────────────

echo "=== Setup: $n wallets (wiping $base) ==="
rm -rf "$base"

declare -a SOL_PK LAU_PK

for ((i=1; i<=n; i++)); do
    lw $i init --insecure          > /dev/null
    lw $i config set-program "$program" > /dev/null
    lw $i config set-pk-dir  "$pk_dir"  > /dev/null

    SOL_PK[$i]=$(lw $i pubkey --sol)
    echo "  Wallet $i Solana: ${SOL_PK[$i]}"
    solana airdrop 10 "${SOL_PK[$i]}" --url "$url" > /dev/null
done

# ── pubkey ────────────────────────────────────────────────────────────────────

echo ""
echo "=== pubkey ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i pubkey)
    check "wallet $i: Solana pubkey shown"   "Solana pubkey"   "$out"
    check "wallet $i: Laurelin pubkey shown" "Laurelin pubkey" "$out"
    LAU_PK[$i]=$(echo "$out" | awk '/Laurelin pubkey:/ { print $3 }')
    echo "  Wallet $i Laurelin: ${LAU_PK[$i]}"
done

# ── SOL balance ───────────────────────────────────────────────────────────────

echo ""
echo "=== SOL balance ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i balance --sol)
    check "wallet $i: SOL balance shown" "SOL balance" "$out"
done

# ── send SOL ──────────────────────────────────────────────────────────────────

echo ""
echo "=== send SOL ==="
out=$(lw 1 send 500000000 --to "${SOL_PK[2]}")
check "wallet 1 → 2: sent 0.5 SOL"      "Sent 500000000 lamports" "$out"
check "wallet 1 → 2: signature returned" "Signature"               "$out"

out=$(lw 2 balance --sol)
check "wallet 2: SOL balance updated" "SOL balance" "$out"

# ── token-list ────────────────────────────────────────────────────────────────

echo ""
echo "=== token-list ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i token-list)
    # Either "No SPL token accounts found." or a table — both are success
    if echo "$out" | grep -qE "No SPL token|Mint"; then
        echo "  PASS: wallet $i: token-list"
        ((PASS++)) || true
    else
        echo "  FAIL: wallet $i: token-list unexpected output: $out"
        ((FAIL++)) || true
    fi
done

# ── stake ─────────────────────────────────────────────────────────────────────

echo ""
echo "=== stake ==="
stake_out=$(lw 1 stake create 1000000000)
check "stake create: account created" "Stake account created" "$stake_out"
check "stake create: signature"       "Signature"             "$stake_out"
STAKE_PK=$(echo "$stake_out" | awk '/Stake account created:/ { print $4 }')
echo "  Stake account: $STAKE_PK"

list_out=$(lw 1 stake list)
check "stake list: shows new account" "$STAKE_PK" "$list_out"

# ── Laurelin: create-account ──────────────────────────────────────────────────

echo ""
echo "=== create-account ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i create-account)
    check "wallet $i: account created" "Account created" "$out"
    check "wallet $i: signature"       "Signature"       "$out"
done

# ── Laurelin: accounts ────────────────────────────────────────────────────────

echo ""
echo "=== accounts ==="
out=$(lw 1 accounts)
#check "accounts: $n found" "${n} account(s) found" "$out"
for ((i=1; i<=n; i++)); do
    check "accounts: wallet $i Laurelin pubkey listed" "${LAU_PK[$i]}" "$out"
done

# ── Laurelin: deposit ─────────────────────────────────────────────────────────

echo ""
echo "=== deposit ==="
#             1         2        3        4
declare -a DEPOSITS=(0 1000000 800000  600000  400000)
for ((i=5; i<=n; i++)); do DEPOSITS[$i]=500000; done

for ((i=1; i<=n; i++)); do
    out=$(lw $i deposit "${DEPOSITS[$i]}")
    check "wallet $i: deposit ${DEPOSITS[$i]} lamports" "Deposit confirmed" "$out"
done

# ── Laurelin: balance after deposit ───────────────────────────────────────────

echo ""
echo "=== balance after deposit ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i balance)
    check "wallet $i: confidential = ${DEPOSITS[$i]}" \
        "Confidential balance:  ${DEPOSITS[$i]} lamports" "$out"
done

# ── Laurelin: ring transfers (wallets 1-4) ────────────────────────────────────
#   T1  1→3  200 000   senderIdx=0 recvIdx=0
#   T2  1→4  150 000   senderIdx=0 recvIdx=1
#   T3  2→3  100 000   senderIdx=1 recvIdx=0
#   T4  2→4   80 000   senderIdx=1 recvIdx=1
# After: 1=650000  2=620000  3=900000  4=630000

echo ""
echo "=== ring transfers ==="
out=$(lw 1 transfer 200000 --to "${LAU_PK[3]}")
check "T1 (1→3, 200000)" "Transfer confirmed" "$out"

out=$(lw 1 transfer 150000 --to "${LAU_PK[4]}")
check "T2 (1→4, 150000)" "Transfer confirmed" "$out"

out=$(lw 2 transfer 100000 --to "${LAU_PK[3]}")
check "T3 (2→3, 100000)" "Transfer confirmed" "$out"

out=$(lw 2 transfer  80000 --to "${LAU_PK[4]}")
check "T4 (2→4,  80000)" "Transfer confirmed" "$out"

# ── history (checked after several confirmed transactions) ────────────────────

echo ""
echo "=== history ==="
out=$(lw 1 history --limit 10)
check "wallet 1: history has entries" "Signature" "$out"

# ── Laurelin: balance after transfers ─────────────────────────────────────────

echo ""
echo "=== balance after transfers ==="
declare -a POST_XFER=(0 650000 620000 900000 630000)
for ((i=5; i<=n; i++)); do POST_XFER[$i]=${DEPOSITS[$i]}; done

for ((i=1; i<=n; i++)); do
    out=$(lw $i balance)
    check "wallet $i: confidential = ${POST_XFER[$i]}" \
        "Confidential balance:  ${POST_XFER[$i]} lamports" "$out"
done

# ── Laurelin: withdraw ────────────────────────────────────────────────────────

echo ""
echo "=== withdraw ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i withdraw "${POST_XFER[$i]}")
    check "wallet $i: withdraw ${POST_XFER[$i]}" "Withdrawal confirmed" "$out"
    check "wallet $i: remaining balance = 0"      "Remaining confidential balance: 0" "$out"
done

# ── Laurelin: balance after withdrawal ────────────────────────────────────────

echo ""
echo "=== balance after withdrawal ==="
for ((i=1; i<=n; i++)); do
    out=$(lw $i balance)
    check "wallet $i: confidential = 0" "Confidential balance:  0 lamports" "$out"
done

# ── Summary ───────────────────────────────────────────────────────────────────

echo ""
echo "=== Results: PASS=$PASS  FAIL=$FAIL ==="
[ "$FAIL" -eq 0 ]
